# OpenAI API key for agent-assisted parsing (optional; deterministic parsing works without it)
OPENAI_API_KEY=sk-your-openai-api-key-here

# API authentication key (must match client header for browser-only development;
# Tauri desktop sidecar supervision sets a per-install key at runtime.)
STATIC_API_KEY=STATIC_KEY_123

# Server port (optional, defaults to 8857)
PORT=8857

# Database path (optional, defaults to usage.db)
DB_PATH=usage.db

# Experimental parser strategy flags
TEMPORAL_FEATURE_DETERMINISTIC_PREFLIGHT=false
TEMPORAL_FEATURE_ORDINAL_WEEKDAY_GRAMMAR=true
TEMPORAL_FEATURE_PLAN_IR=true
TEMPORAL_FEATURE_SEMANTIC_CONSISTENCY_GATE=false

# Local Temporal SLM endpoint. scripts/start-temporal-peft-server.ps1 serves this on port 8765.
TEMPORAL_PLAN_IR_ENDPOINT_BASE_URL=http://127.0.0.1:8765/v1
TEMPORAL_PLAN_IR_ENDPOINT_MODEL=qwen-temporal-ir-qwen35-bf16-chat-noisy-input-2584
TEMPORAL_PLAN_IR_ENDPOINT_INSTRUCTION_PRESET=minimal
TEMPORAL_PLAN_IR_ENDPOINT_API=chat
TEMPORAL_PLAN_IR_ENDPOINT_PROMPT_FORMAT=chat
TEMPORAL_PLAN_IR_ENDPOINT_MAX_TOKENS=512
TEMPORAL_PLAN_IR_ENDPOINT_TIMEOUT_MS=15000
