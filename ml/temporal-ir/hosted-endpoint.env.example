# Copy these values into a local ignored shell/env file or set them directly.
# Do not commit real provider tokens.

TEMPORAL_EVAL_BASELINES=endpoint-plan
TEMPORAL_EVAL_ENDPOINT_BASE_URL=https://example.provider/v1
TEMPORAL_EVAL_ENDPOINT_MODEL=qwen-temporal-ir
TEMPORAL_EVAL_ENDPOINT_API_KEY=replace-with-local-secret
TEMPORAL_EVAL_ENDPOINT_PROVIDER=runpod-vllm
TEMPORAL_EVAL_ENDPOINT_INSTRUCTION_PRESET=minimal
TEMPORAL_EVAL_ENDPOINT_API=completions
TEMPORAL_EVAL_ENDPOINT_RESPONSE_FORMAT=none
TEMPORAL_EVAL_ENDPOINT_MAX_TOKENS=192
# For chat-trained reasoning models, override with:
# TEMPORAL_EVAL_ENDPOINT_API=chat
# TEMPORAL_EVAL_ENDPOINT_RESPONSE_FORMAT=json_schema
# TEMPORAL_EVAL_ENDPOINT_EXTRA_BODY={"chat_template_kwargs":{"enable_thinking":false}}
